{% extends 'base.html.twig' %}

{% block title %}Evenement{% endblock %}

{% block body %}

<div>
    <h1>{{ event is defined and event.id ? 'Modifier' : 'Creer' }} un evenement</h1>
</div>

<div>
    <a href="{{ path('app_admin') }}">Retour admin</a>
</div>

<div>
    {{ form_start(form) }}

    <div>
        {{ form_label(form.titre, 'Titre') }}
        {{ form_widget(form.titre) }}
        {{ form_errors(form.titre) }}
    </div>

    <div>
        {{ form_label(form.description, 'Description') }}
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>

    <div>
        {{ form_label(form.date_debut, 'Date de debut') }}
        {{ form_widget(form.date_debut) }}
        {{ form_errors(form.date_debut) }}
    </div>

    <div>
        {{ form_label(form.date_fin, 'Date de fin') }}
        {{ form_widget(form.date_fin) }}
        {{ form_errors(form.date_fin) }}
    </div>

    <div>
        {{ form_label(form.salle, 'Salle') }}
        {{ form_widget(form.salle) }}
        {{ form_errors(form.salle) }}
    </div>

    <div>
        {{ form_label(form.intervenant, 'Intervenant') }}
        {{ form_widget(form.intervenant) }}
        {{ form_errors(form.intervenant) }}
    </div>

    <div>
        {{ form_label(form.promo, 'Promo') }}
        {{ form_widget(form.promo) }}
        {{ form_errors(form.promo) }}
    </div>

    <div>
        <button type="submit">Enregistrer</button>
        <a href="{{ path('app_admin') }}">Annuler</a>
    </div>

    {{ form_end(form) }}
</div>

{% endblock %}